# Backend environment template
# Copy to .env (development) or .env.prod (production) and adjust values.

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1            # keep 1 for SQLite; raise to 2+ if you switch to Postgres
ENVIRONMENT=production
DEBUG=False

# ── Database ──────────────────────────────────────────────────────────────────
# Path inside the container — matches the named volume mount /app/data
DATABASE_URL=sqlite:////app/data/genome_lens.db

# ── Seed data ─────────────────────────────────────────────────────────────────
# Path inside the container — matches COPY genes_human.csv /app/
CSV_PATH=/app/genes_human.csv

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list — set to your real domain in production
# In dev the browser hits the backend directly on :8000 (different port = cross-origin).
# List every origin that will call the API: the nginx-served frontend (:80),
CORS_ORIGINS=https://yourdomain.com

# ── External APIs ─────────────────────────────────────────────────────────────
GTEX_API_BASE=https://gtexportal.org/api/v2
MYGENE_API_BASE=https://mygene.info/v3
