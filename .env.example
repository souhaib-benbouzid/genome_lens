# Copy this file to .env and fill in values before running docker compose.
# All vars have safe defaults in the compose files — only override what you need.

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1            # keep 1 for SQLite; raise to 2+ if you switch to Postgres
ENVIRONMENT=production
DEBUG=False

# ── Database ──────────────────────────────────────────────────────────────────
# Path inside the container — matched to the named volume mount /app/data
DATABASE_URL=sqlite:////app/data/genome_lens.db

# ── Seed data ─────────────────────────────────────────────────────────────────
# Path inside the container — matched to COPY genes_human.csv /app/
CSV_PATH=/app/genes_human.csv

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list — set to your real domain in production
CORS_ORIGINS=https://yourdomain.com

# ── External APIs ─────────────────────────────────────────────────────────────
GTEX_API_BASE=https://gtexportal.org/api/v2
MYGENE_API_BASE=https://mygene.info/v3

# ── Frontend ──────────────────────────────────────────────────────────────────
# Host port that nginx binds to — Coolify/Traefik sits in front of this
FRONTEND_PORT=80
